{
  "appId": "com.Joanium.app",
  "productName": "Joanium",
  "directories": {
    "output": "dist"
  },
  "files": [
    "App.js",
    "Core/**/*",
    "Packages/**/*",
    "Public/**/*",
    "Assets/**/*",
    "SystemInstructions/**/*"
  ],
  "extraResources": [
    {
      "from": "Config/Models",
      "to": "Config/Models"
    },
    {
      "from": "Config/WindowState.json",
      "to": "Config/WindowState.json"
    },
    {
      "from": "Marketplace/Persona/Joanium/Joana.md",
      "to": "Marketplace/Persona/Joanium/Joana.md"
    }
  ],
  "win": {
    "icon": "Assets/Logo/Logo.ico"
  },
  "mac": {
    "icon": "Assets/Logo/Logo.icns"
  },
  "linux": {
    "icon": "Assets/Logo/Logo.png"
  }
}
